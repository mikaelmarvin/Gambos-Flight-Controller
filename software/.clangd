# Extra system includes for clangd (arm-none-eabi newlib lives outside project -I flags).
# Adjust GCC version in paths if `arm-none-eabi-gcc -E -v` shows a different 10.3.1.
#
# compile_commands.json must point at the active board, e.g.:
#   project/compile_commands.json -> build/custom/compile_commands.json
# Restart clangd after switching boards (Command Palette → "clangd: Restart language server").

---
# Only index TUs from compile_commands.json (avoids devkit/custom duplicate symbols).
Index:
  Background: Build

---
# Inactive board (when compile_commands points at custom).
If:
  PathMatch: project/app/devkit/.*
Index:
  Background: Skip

---
If:
  PathMatch: project/board/devkit/.*
Index:
  Background: Skip

---
# Same newlib/gcc paths (arm-none-eabi toolchain); board-selected compile_commands.
If:
  PathMatch: project/custom_drivers/.*
CompileFlags:
  CompilationDatabase: project
  Add:
    - -I
    - project/custom_drivers
    - -I
    - project/custom_drivers/nrf24l01p
    - -isystem
    - /usr/lib/gcc/arm-none-eabi/10.3.1/include
    - -isystem
    - /usr/lib/gcc/arm-none-eabi/10.3.1/include-fixed
    - -isystem
    - /usr/include/newlib
    - -isystem
    - /usr/lib/arm-none-eabi/include/c++/10.3.1
    - -isystem
    - /usr/lib/arm-none-eabi/include/c++/10.3.1/arm-none-eabi
    - -isystem
    - /usr/lib/arm-none-eabi/include/c++/10.3.1/backward

---
If:
  PathMatch: project/.*
CompileFlags:
  CompilationDatabase: project
  Add:
    - -isystem
    - /usr/lib/gcc/arm-none-eabi/10.3.1/include
    - -isystem
    - /usr/lib/gcc/arm-none-eabi/10.3.1/include-fixed
    - -isystem
    - /usr/include/newlib
    - -isystem
    - /usr/lib/arm-none-eabi/include/c++/10.3.1
    - -isystem
    - /usr/lib/arm-none-eabi/include/c++/10.3.1/arm-none-eabi
    - -isystem
    - /usr/lib/arm-none-eabi/include/c++/10.3.1/backward

# Hide inline parameter-name labels (clangd inlay hints); they are not part of the source.
---
InlayHints:
  ParameterNames: No
