{
  "cortex-debug.armToolchainPath": "/usr/bin",
  "cortex-debug.gdbPath": "/usr/bin/gdb-multiarch",
  "editor.formatOnSave": true,
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 70
  },
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.wordWrap": "wordWrapColumn",
    "editor.wordWrapColumn": 70
  },
  "C_Cpp.default.compileCommands": "${workspaceFolder}/software/project/compile_commands.json",
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.errorSquiggles": "disabled",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/software/project"
  ],
  "cmake.ignoreCMakeListsMissing": true,
  "chat.disableAIFeatures": true
}